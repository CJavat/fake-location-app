# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local environment files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

.claude/
.vscode/

*.apk

# EXPO_PUBLIC_* vars here are meant to be embedded in the client bundle
# (the Mapbox access token is a publishable token), and the build needs
# this file present to inline them into the release JS bundle.
!.env
